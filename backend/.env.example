# Default URL matches docker-compose.yml at repo root (no personal Postgres password).
# 1) docker compose up -d
# 2) cp .env.example .env
DATABASE_URL=postgresql://clearview:clearview@localhost:5433/clearview
NEWSAPI_KEY=your_newsapi_key_here
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key_here
# WebCite — https://webcite.co (sources/search, 2 credits/call)
WEBCITE_API_KEY=your_webcite_api_key_here
WEBCITE_SOURCES_LIMIT=10
API_PREFIX=/api/v1
