# Replace YOUR_MAC_USERNAME with: whoami
# Uses Unix socket (not TCP), so you usually avoid "fe_sendauth: no password supplied" on Mac.
# If connection fails, run: psql -c "SHOW unix_socket_directories;" and replace /tmp below.
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@/clearview?host=/tmp
NEWSAPI_KEY=your_newsapi_key_here
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key_here
API_PREFIX=/api/v1
